# Secrets — never commit. Keys leaked in git history = drained wallet.
.env
*.keystore
credentials*.json

# Runtime state and logs — private, EXCEPT the x402 payments ledger, which is
# just on-chain proof of the charges (tx hashes + public wallet) and is tracked.
data/*
!data/payments.jsonl

# Private strategy selection — never publish the real watchlist
config/watchlist.local.yaml

# Local operational demo script (server-specific: domain, wallet addresses) —
# kept in the working tree, never committed.
DEMO.md

# Private pre-competition checklist (capital, funding, position details) —
# kept in the working tree, never committed.
PRE_COMPETITION.md

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/

# Local x402 pay-side demo capture (CMC premium TA payload) — local artifact.
cmc_ta.json
