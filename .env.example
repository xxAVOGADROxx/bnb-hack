# CoinMarketCap Pro API key (https://pro.coinmarketcap.com)
CMC_PRO_API_KEY=

# Trust Wallet Agent Kit auth (issued at https://portal.trustwallet.com)
TW_ACCESS_ID=
TW_HMAC_SECRET=

# Optional: wallet password for headless servers without an OS keychain.
# Prefer the OS keychain; never store seed phrases or private keys anywhere.
# TWAK_WALLET_PASSWORD=

# Optional: use `twak serve --rest` instead of the CLI subprocess.
# NOT recommended for deployment — the CLI transport is the validated path
# (the REST swap action races the token approval; see deploy/DEPLOY.md).
# TWAK_SERVE_URL=http://127.0.0.1:3000

# Optional: our agent wallet address (used by the read-only leaderboard
# monitor to find our row in the field). Public info, safe to set.
AGENT_WALLET_ADDRESS=

# Optional: human alerts + tx/balance notifications (Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Password for the DEDICATED x402 payments/settlement wallet (separate keystore
# ~/.twak/x402-wallet.json, created by scripts/create_x402_wallet.py). Only the
# x402 server uses it; it is NEVER the trading wallet, so x402 settlements don't
# contend for the trading nonce and the public server never holds the trading key.
# X402_WALLET_PASSWORD=

# Optional: route the pay-side premium TA call through the local SSE proxy
# (agent/x402/sse_proxy.py) that injects the Accept header twak omits. Unset =
# call CMC directly (default). Set this to enable the paid tie-break path.
# CMC_X402_MCP_URL=http://127.0.0.1:8403/x402/mcp
